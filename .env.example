# Storage
DATA_ROOT=./data

# Ports
API_PORT=8002
WEB_PORT=3031

# API URLs
# NEXT_PUBLIC_API_URL: Used by browser for direct API calls (HTTP only)
NEXT_PUBLIC_API_URL=http://localhost:8002
# API_URL: Used by Next.js server-side proxy (internal Docker network in production)
API_URL=http://localhost:8002

# AI Provider (codex | anthropic | openai)
AI_PROVIDER=codex

# AI API Keys (required for anthropic/openai providers)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Auth (required for production)
# NEXTAUTH_URL=https://zora.chrisx.art
# NEXTAUTH_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Database (production only)
# DATABASE_URL=postgresql://zora:zora_password@db:5432/zora
# DB_PASSWORD=zora_password

# Research APIs
# SEMANTIC_SCHOLAR_API_KEY=
UNPAYWALL_EMAIL=zora@localhost
